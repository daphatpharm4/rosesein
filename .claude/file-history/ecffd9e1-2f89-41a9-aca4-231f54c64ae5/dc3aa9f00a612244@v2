## Phase 1: Foundation — `shared/verticals.ts`

Create the vertical registry as the single source of truth.

**File: `shared/verticals.ts`** (NEW)

```ts
export interface VerticalConfig {
  id: string;                          // e.g. "pharmacy"
  labelEn: string;                     // "Pharmacy"
  labelFr: string;                     // "Pharmacie"
  pluralEn: string;                    // "Pharmacies"
  pluralFr: string;                    // "Pharmacies"
  icon: string;                        // lucide icon name: "pill"
  color: string;                       // marker color hex
  enrichableFields: string[];          // fields that can be enriched
  createRequiredFields: string[];      // fields required on CREATE
  normalizeDetails: (d: SubmissionDetails) => SubmissionDetails;  // category-specific normalization
}

export const VERTICALS: Record<string, VerticalConfig> = { ... };

// Derived helpers
export const VERTICAL_IDS: string[] = Object.keys(VERTICALS);
export const SUBMISSION_CATEGORIES = VERTICAL_IDS as SubmissionCategory[];
export function isValidCategory(v: string): v is SubmissionCategory { ... }
export function getVertical(id: string): VerticalConfig { ... }
export function categoryLabel(id: string, lang: 'en' | 'fr'): string { ... }
export function categoryPluralLabel(id: string, lang: 'en' | 'fr'): string { ... }
```

